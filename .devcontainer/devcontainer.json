// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
    "name": "librmcs-develop",
    "image": "qzhhhi/librmcs-develop:latest",
    "privileged": true,
    // Avoid host-shell startup hooks during Dev Containers environment probing.
    "userEnvProbe": "none",
    "mounts": [
        {
            "source": "/dev",
            "target": "/dev",
            "type": "bind"
        },
        {
            "source": "/tmp/.X11-unix",
            "target": "/tmp/.X11-unix",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}",
            "target": "/mnt/home",
            "type": "bind"
        }
    ],
    "onCreateCommand": "bash -c '[ -d /mnt/home/.codex ] && ln -sfn /mnt/home/.codex ~/.codex; [ -d /mnt/home/.claude ] && ln -sfn /mnt/home/.claude ~/.claude; true'",
    // Personal CLI bootstrapping is opt-in to keep container creation fast and deterministic.
    "postCreateCommand": "bash -c 'if [ \"${RMCS_DEVCONTAINER_INSTALL_USER_TOOLS:-0}\" = 1 ]; then if [ -d ~/.codex ] && ! command -v codex >/dev/null 2>&1; then sudo npm i -g @openai/codex; fi; if [ -d ~/.claude ] && ! command -v claude >/dev/null 2>&1; then curl -fsSL https://claude.ai/install.sh | bash && sudo ln -sf ~/.local/bin/claude /usr/local/bin/claude; fi; fi'",
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "HTTP_PROXY": "${localEnv:HTTP_PROXY}",
        "HTTPS_PROXY": "${localEnv:HTTPS_PROXY}",
        "NO_PROXY": "${localEnv:NO_PROXY}",
        "http_proxy": "${localEnv:http_proxy}",
        "https_proxy": "${localEnv:https_proxy}",
        "no_proxy": "${localEnv:no_proxy}",
        "HOST_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
    },
    "runArgs": [
        "--network=host"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "remote.autoForwardPorts": false
            },
            "extensions": [
                // C++ language support
                "llvm-vs-code-extensions.vscode-clangd",
                // Python language support
                "ms-python.vscode-pylance",
                "ms-python.python",
                "ms-python.debugpy",
                // CMake language support
                "KylinIdeTeam.cmake-intellisence",
                // Code spell checking
                "streetsidesoftware.code-spell-checker",
                // Git enhancements
                "mhutchie.git-graph"
            ]
        }
    }
}
